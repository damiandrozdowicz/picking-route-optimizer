{
  "name": "warehouse-order-picking-assistant",
  "version": "1.0.0",
  "description": "Service to support on-prem staff in finding items to complete orders in most optimal way.",
  "license": "ISC",
  "author": "Damian Drozdowicz",
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
